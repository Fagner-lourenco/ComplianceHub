rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Basic verification
    function isAuthenticated() {
      return request.auth != null;
    }

    // Get the current user's profile document
    function getUserProfile() {
      return get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data;
    }

    // Check if document belongs to the same tenant as the user
    function isSameTenant(tenantId) {
      return getUserProfile() != null && getUserProfile().tenantId == tenantId;
    }

    // Check if user is internal staff
    function isAnalyst() {
      return getUserProfile() != null && getUserProfile().role in ['analyst', 'supervisor', 'admin'];
    }

    // Check if user is admin specifically
    function isAdmin() {
      return getUserProfile() != null && getUserProfile().role == 'admin';
    }

    // Check if user is a client
    function isClient() {
      return getUserProfile() != null && getUserProfile().role in ['CLIENT', 'client_viewer', 'client_manager'];
    }


    /* --- COLLECTION RULES --- */

    // 1. User Profiles
    match /userProfiles/{userId} {
      // Users can read their own profile, analysts can read all, clients can read their own tenant's users
      allow read: if isAuthenticated() && (
        request.auth.uid == userId ||
        isAnalyst() ||
        (isClient() && isSameTenant(resource.data.tenantId))
      );
      
      // Profiles are provisioned and managed only by internal staff.
      // This blocks self-promotion of role or tenant context from the client.
      allow create, update, delete: if isAuthenticated() && isAnalyst();
    }

    // 2. Cases
    match /cases/{caseId} {
      // Analysts see all cases. Clients see only their tenant's cases.
      allow read: if isAuthenticated() && (
        isAnalyst() || 
        (isClient() && isSameTenant(resource.data.tenantId))
      );

      // Analysts can update any case.
      // Clients can only update cases in CORRECTION_NEEDED status, changing only allowed fields and setting status back to PENDING.
      allow update: if isAuthenticated() && (
        isAnalyst() || 
        (isClient() && isSameTenant(resource.data.tenantId) &&
         resource.data.status == 'CORRECTION_NEEDED' &&
         request.resource.data.status == 'PENDING' &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(
           ['candidateName', 'cpf', 'cpfMasked', 'socialProfiles', 'status', 'correctedAt', 'correctedBy', 'corrections', 'updatedAt']
         )
        )
      );
      
      allow create: if isAuthenticated() && (
        isAnalyst() || 
        (isClient() && isSameTenant(request.resource.data.tenantId))
      );
      
      allow delete: if isAuthenticated() && isAdmin();
    }

    // 3. Candidates
    match /candidates/{candidateId} {
      allow read, update: if isAuthenticated() && (
        isAnalyst() || 
        (isClient() && isSameTenant(resource.data.tenantId))
      );
      
      allow create: if isAuthenticated() && (
        isAnalyst() || 
        (isClient() && isSameTenant(request.resource.data.tenantId))
      );
      
      allow delete: if isAuthenticated() && isAdmin();
    }

    // 4. Audit Logs
    match /auditLogs/{logId} {
      allow read: if isAuthenticated() && (
        isAnalyst() || 
        (isClient() && isSameTenant(resource.data.tenantId))
      );
      
      allow create: if isAuthenticated() && (
        isAnalyst() || 
        (isClient() && isSameTenant(request.resource.data.tenantId))
      );
      
      allow update, delete: if false; // Logs are immutable
    }

    // 5. Tenant Settings
    match /tenantSettings/{tenantId} {
      allow read: if isAuthenticated() && (
        isAnalyst() ||
        (isClient() && isSameTenant(tenantId))
      );

      allow create, update: if isAuthenticated() && isAnalyst();
      allow delete: if false;
    }

    // 6. Exports
    match /exports/{exportId} {
      allow read: if isAuthenticated() && (
        isAnalyst() || 
        (isClient() && isSameTenant(resource.data.tenantId))
      );
      
      allow create: if isAuthenticated() && (
        isAnalyst() || 
        (isClient() && isSameTenant(request.resource.data.tenantId))
      );
      
      allow delete: if false;
    }

    // 7. Public Reports (shareable links — public read, authenticated create)
    match /publicReports/{token} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }
  }
}
