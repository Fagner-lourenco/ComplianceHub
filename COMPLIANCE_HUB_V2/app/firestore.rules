rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Basic verification
    function isAuthenticated() {
      return request.auth != null;
    }

    // Get the current user's profile document
    function getUserProfile() {
      return get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data;
    }

    // Fast role check via custom claims (set by Cloud Functions on user creation/update).
    // Falls back to getUserProfile() when claims are not yet propagated.
    function getUserRole() {
      return request.auth.token.role != null
        ? request.auth.token.role
        : getUserProfile().role;
    }

    function getUserTenantId() {
      return request.auth.token.tenantId != null
        ? request.auth.token.tenantId
        : getUserProfile().tenantId;
    }

    // Check if document belongs to the same tenant as the user
    function isSameTenant(tenantId) {
      let userTenantId = getUserTenantId();
      return userTenantId != null && tenantId != null && userTenantId == tenantId;
    }

    // Check if user is internal staff
    function isAnalyst() {
      return getUserRole() in ['analyst', 'senior_analyst', 'supervisor', 'admin'];
    }

    // Sensitive raw data is limited to senior operational profiles.
    function canReadRawEvidence() {
      return getUserRole() in ['senior_analyst', 'supervisor', 'admin'];
    }

    // Check if user is admin specifically
    function isAdmin() {
      return getUserRole() == 'admin';
    }

    // Check if user is a client
    function isClient() {
      return getUserRole() in ['CLIENT', 'client_viewer', 'client_operator', 'client_manager'];
    }

    function isGlobalAdmin() {
      return getUserRole() == 'admin' && getUserTenantId() == null;
    }

    function canReadTenantDoc(tenantId) {
      return isAuthenticated() && isAnalyst() && (
        isGlobalAdmin() ||
        isSameTenant(tenantId)
      );
    }

    function canReadRawTenantDoc(tenantId) {
      return isAuthenticated() && canReadRawEvidence() && (
        isGlobalAdmin() ||
        isSameTenant(tenantId)
      );
    }

    /* --- COLLECTION RULES --- */

    // 1. User Profiles
    match /userProfiles/{userId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == userId ||
        isAnalyst()
      );
      allow create, update, delete: if isAuthenticated() && isAnalyst();
    }

    // 2. Cases
    match /cases/{caseId} {
      allow read: if isAuthenticated() && isAnalyst() && isSameTenant(resource.data.tenantId);
      allow update: if isAuthenticated() && isAnalyst() && isSameTenant(resource.data.tenantId);
      allow create: if isAuthenticated() && isAnalyst() && isSameTenant(request.resource.data.tenantId);
      allow delete: if isAuthenticated() && isAdmin();

      // 2a. Public Result — sanitized subcollection for client access
      match /publicResult/{docId} {
        allow read: if isAuthenticated() && (
          isAnalyst() ||
          (isClient() && isSameTenant(get(/databases/$(database)/documents/cases/$(caseId)).data.tenantId))
        );
        allow create, update, delete: if false;
      }

      // 2b. AI Cache
      match /aiCache/{docId} {
        allow read: if isAuthenticated() && isAnalyst();
        allow create, update, delete: if false;
      }
    }

    // 2c. Client-safe mirrors and projections
    match /clientCases/{caseId} {
      allow read: if isAuthenticated() && (
        isAnalyst() ||
        (isClient() && isSameTenant(resource.data.tenantId))
      );
      allow create, update, delete: if false;
    }

    match /clientProjections/{caseId} {
      allow read: if isAuthenticated() && (
        isAnalyst() ||
        (isClient() && isSameTenant(resource.data.tenantId))
      );
      allow create, update, delete: if false;
    }

    match /clientCaseList/{caseId} {
      allow read: if isAuthenticated() && (
        isAnalyst() ||
        (isClient() && isSameTenant(resource.data.tenantId))
      );
      allow create, update, delete: if false;
    }

    // 2e. V2 operational/reporting contracts
    match /decisions/{decisionId} {
      allow read: if canReadTenantDoc(resource.data.tenantId);
      allow create, update, delete: if false;
    }

    match /reportSnapshots/{snapshotId} {
      allow read: if canReadTenantDoc(resource.data.tenantId);
      allow create, update, delete: if false;
    }

    match /moduleRuns/{moduleRunId} {
      allow read: if canReadTenantDoc(resource.data.tenantId);
      allow create, update, delete: if false;
    }

    match /subjects/{subjectId} {
      allow read: if canReadTenantDoc(resource.data.tenantId);
      allow create, update, delete: if false;
    }

    match /persons/{personId} {
      allow read: if canReadTenantDoc(resource.data.tenantId);
      allow create, update, delete: if false;
    }

    match /companies/{companyId} {
      allow read: if canReadTenantDoc(resource.data.tenantId);
      allow create, update, delete: if false;
    }

    match /facts/{factId} {
      allow read: if canReadTenantDoc(resource.data.tenantId);
      allow create, update, delete: if false;
    }

    match /relationships/{relationshipId} {
      allow read: if canReadTenantDoc(resource.data.tenantId);
      allow create, update, delete: if false;
    }

    match /timelineEvents/{eventId} {
      allow read: if canReadTenantDoc(resource.data.tenantId);
      allow create, update, delete: if false;
    }

    match /providerDivergences/{divergenceId} {
      allow read: if canReadTenantDoc(resource.data.tenantId);
      allow create, update, delete: if false;
    }

    match /providerRequests/{requestId} {
      allow read: if canReadTenantDoc(resource.data.tenantId);
      allow create, update, delete: if false;
    }

    match /rawSnapshots/{snapshotId} {
      allow read: if canReadRawTenantDoc(resource.data.tenantId);
      allow create, update, delete: if false;
    }

    match /providerRecords/{recordId} {
      allow read: if canReadRawTenantDoc(resource.data.tenantId);
      allow create, update, delete: if false;
    }

    match /evidenceItems/{evidenceId} {
      allow read: if canReadTenantDoc(resource.data.tenantId);
      allow create, update, delete: if false;
    }

    match /riskSignals/{signalId} {
      allow read: if canReadTenantDoc(resource.data.tenantId);
      allow create, update, delete: if false;
    }

    match /usageMeters/{usageMeterId} {
      allow read: if canReadTenantDoc(resource.data.tenantId);
      allow create, update, delete: if false;
    }

    // 3. Candidates
    match /candidates/{candidateId} {
      allow read, update: if isAuthenticated() && isAnalyst() && isSameTenant(resource.data.tenantId);
      allow create: if isAuthenticated() && isAnalyst();
      allow delete: if isAuthenticated() && isAdmin();
    }

    // 4. Audit Logs
    match /auditLogs/{logId} {
      allow read: if canReadTenantDoc(resource.data.tenantId);
      allow create: if false;
      allow update, delete: if false;
    }

    match /tenantAuditLogs/{logId} {
      allow read: if isAuthenticated() && (
        isAnalyst() ||
        (isClient() && isSameTenant(resource.data.tenantId))
      );
      allow create, update, delete: if false;
    }

    // 5. Tenant Settings
    match /tenantSettings/{tenantId} {
      allow read: if isAuthenticated() && (
        isAnalyst() ||
        (isClient() && isSameTenant(tenantId))
      );
      allow create, update: if false;
      allow delete: if false;
    }

    match /tenantEntitlements/{tenantId} {
      allow read: if canReadTenantDoc(tenantId);
      allow create, update, delete: if false;
    }

    match /tenantConfigs/{tenantId} {
      allow read: if canReadTenantDoc(tenantId);
      allow create, update, delete: if false;
    }

    // 6. Exports
    match /exports/{exportId} {
      allow read: if isAuthenticated() && (
        isAnalyst() || 
        (isClient() && isSameTenant(resource.data.tenantId))
      );
      allow create: if false;
      allow delete: if false;
    }

    // 7. Public Reports
    match /publicReports/{token} {
      allow read: if 
        (isAuthenticated() && isAnalyst()) ||
        (
          resource.data.expiresAt is timestamp
          && request.time < resource.data.expiresAt
          && (resource.data.active != false)
        );
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // 8. System Health
    match /systemHealth/{providerId} {
      allow read: if isAuthenticated() && isAnalyst();
      allow create, update, delete: if false;
    }

    // 9. Tenant Usage
    match /tenantUsage/{tenantId} {
      allow read: if isAuthenticated() && (
        isAnalyst() ||
        (isClient() && isSameTenant(tenantId))
      );
      allow create, update, delete: if false;
    }

    match /billingSettlements/{settlementId} {
      allow read: if canReadTenantDoc(resource.data.tenantId);
      allow create, update, delete: if false;
    }

    match /billingEntries/{entryId} {
      allow read: if canReadTenantDoc(resource.data.tenantId);
      allow create, update, delete: if false;
    }

    match /watchlists/{watchlistId} {
      allow read: if canReadTenantDoc(resource.data.tenantId);
      allow create, update, delete: if false;
    }

    match /seniorReviewRequests/{requestId} {
      allow read: if canReadTenantDoc(resource.data.tenantId);
      allow create, update, delete: if false;
    }

    match /quoteRequests/{quoteId} {
      allow read: if isAuthenticated() && (
        isAnalyst() ||
        (isClient() && isSameTenant(resource.data.tenantId))
      );
      allow create, update, delete: if false;
    }

    match /monitoringSubscriptions/{subscriptionId} {
      allow read: if canReadTenantDoc(resource.data.tenantId);
      allow create, update, delete: if false;
    }

    match /alerts/{alertId} {
      allow read: if canReadTenantDoc(resource.data.tenantId) ||
        (isAuthenticated() && isClient() && isSameTenant(resource.data.tenantId));
      allow create, update, delete: if false;
    }
  }
}
