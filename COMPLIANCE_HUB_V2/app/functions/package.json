{
  "name": "compliancehub-functions",
  "private": true,
  "engines": {
    "node": "22"
  },
  "main": "index.js",
  "scripts": {
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint ."
  },
  "dependencies": {
    "firebase-admin": "^13.7.0",
    "firebase-functions": "^7.2.3"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "domain/**/*.js",
      "helpers/**/*.js",
      "application/**/*.js"
    ],
    "coveragePathIgnorePatterns": [
      "node_modules",
      "bootstrap.js"
    ]
  }
}
